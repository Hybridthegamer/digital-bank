# Copy to .env and customise for your environment

# PostgreSQL
DATABASE_URL=postgresql://sdps:sdpspass123@postgres:5432/sdps

# Redis
REDIS_URL=redis://redis:6379/0

# HMAC secret — change in production
SECRET_KEY=change-me-in-production-must-be-32-ch

# AES-256 encryption key (base64-encoded 32 bytes) — generate with:
# python3 -c "import base64,os; print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=dGhpcyBpcyBhIDMyLWJ5dGUgZW5jcnlwdGlvbg==

APP_ENV=development
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_HOURS=24
FRAUD_THRESHOLD_LOW=0.40
FRAUD_THRESHOLD_HIGH=0.75
